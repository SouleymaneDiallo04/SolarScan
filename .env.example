# Configuration de déploiement SolarScan — copier en `.env` et ajuster.
#   cp .env.example .env

# Identifiants PostgreSQL/PostGIS
POSTGRES_USER=solarscan
POSTGRES_PASSWORD=change-me-en-prod
POSTGRES_DB=solarscan

# Port d'exposition du dashboard/API sur l'hôte (http://localhost:API_PORT/)
API_PORT=8090

# Chemin du modèle entraîné sur l'hôte (monté en lecture seule dans le conteneur)
MODEL_FILE=./solarscan_resnet18.pt
